<% layout("/layouts/boilerplate") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

/* Page Background */

.success-page{
min-height:100vh;
background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
display:flex;
align-items:center;
justify-content:center;
padding:60px 20px;
font-family:Segoe UI;
}

/* Glass Card */

.success-card{
max-width:850px;
width:100%;
background:rgba(255,255,255,0.08);
backdrop-filter:blur(15px);
border-radius:20px;
border:1px solid rgba(255,255,255,0.2);
padding:35px;
color:white;
box-shadow:0 10px 30px rgba(0,0,0,0.4);
}

/* Success Icon */

.success-icon{
font-size:60px;
}

/* Listing Image */

.listing-img{
width:100%;
height:260px;
object-fit:cover;
border-radius:12px;
}

/* Info Row */

.info-row{
display:flex;
justify-content:space-between;
padding:10px 0;
border-bottom:1px solid rgba(255,255,255,0.2);
}

/* Buttons */

.buttons{
margin-top:30px;
}

</style>


<div class="success-page">

<div class="success-card">

<div class="text-center mb-4">

<div class="success-icon text-success">✅</div>

<h2 class="mt-2">Booking Confirmed</h2>

<p class="text-light">Your hotel booking has been successfully completed.</p>

</div>


<div class="row align-items-center">

<div class="col-md-6">
<img src="<%= listing.image.url %>" class="listing-img" alt="listing_image">
</div>


<div class="col-md-6">

<h4><%= listing.title %></h4>

<p class="text-light"><%= listing.location %></p>

<hr style="border-color:rgba(255,255,255,0.2)">

<div class="info-row">
<span><strong>Amount Paid</strong></span>
<span>₹<%= listing.price %></span>
</div>

<div class="info-row">
<span><strong>Booking ID</strong></span>
<span>BK<%= listing._id.toString().slice(-6) %></span>
</div>

<div class="info-row">
<span><strong>Status</strong></span>
<span class="text-success">Confirmed</span>
</div>

<div class="info-row">
<span><strong>Date</strong></span>
<span><%= new Date().toLocaleDateString() %></span>
</div>

</div>

</div>


<div class="text-center buttons">

<a href="/listings/<%= listing._id %>" class="btn btn-success me-2">
View Listing
</a>

<a href="/" class="btn btn-primary">
Go to Homepage
</a>

</div>

</div>

</div>
