<% layout("/layouts/boilerplate") %>
<!DOCTYPE html>
<html>
<head>
<title>Booking Confirmed</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
background:#f5f7fa;
font-family:Arial, sans-serif;
}

.success-card{
max-width:800px;
margin:70px auto;
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 6px 20px rgba(0,0,0,0.1);
}

.success-icon{
font-size:50px;
}

.listing-img{
width:100%;
height:250px;
object-fit:cover;
border-radius:10px;
}

.info-row{
display:flex;
justify-content:space-between;
padding:8px 0;
border-bottom:1px solid #eee;
}

.buttons{
margin-top:25px;
}
</style>

</head>

<body>

<div class="container">

<div class="success-card">

<div class="text-center mb-4">

<div class="success-icon text-success">✅</div>
<h2 class="mt-2">Booking Confirmed</h2>

</div>

<div class="row align-items-center">

<div class="col-md-6">
<img src="<%= listing.image.url %>" class="listing-img" alt="listing_image">
</div>

<div class="col-md-6">

<h4><%= listing.title %></h4>

<p class="text-muted"><%= listing.location %></p>

<hr>

<div class="info-row">
<span><strong>Amount Paid</strong></span>
<span>₹<%= listing.price %></span>
</div>

<div class="info-row">
<span><strong>Booking ID</strong></span>
<span>BK<%= listing._id.toString().slice(-6) %></span>
</div>

<div class="info-row">
<span><strong>Status</strong></span>
<span class="text-success">Confirmed</span>
</div>

<div class="info-row">
<span><strong>Date</strong></span>
<span><%= new Date().toLocaleDateString() %></span>
</div>

</div>

</div>

<div class="text-center buttons">

<a href="/listings/<%= listing._id %>" class="btn btn-success me-2">
View Listing
</a>

<a href="/" class="btn btn-primary">
Go to Homepage
</a>

</div>

</div>

</div>

</body>
</html>
