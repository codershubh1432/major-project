<!DOCTYPE html>
<html>
<head>
<title>Booking Page</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
height:100vh;
background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
display:flex;
align-items:center;
justify-content:center;
font-family:Segoe UI;
}

/* Glass Card */

.booking-card{
width:520px;
backdrop-filter:blur(15px);
background:rgba(255,255,255,0.08);
border-radius:20px;
border:1px solid rgba(255,255,255,0.2);
padding:30px;
color:white;
box-shadow:0 10px 30px rgba(0,0,0,0.4);
}

/* Listing Image */

.listing-img{
width:100%;
height:220px;
object-fit:cover;
border-radius:12px;
margin-bottom:15px;
}

/* Title */

.title{
font-size:26px;
font-weight:600;
}

/* Location */

.location{
opacity:0.8;
margin-bottom:10px;
}

/* Price */

.price{
font-size:24px;
font-weight:bold;
color:#00ffb3;
margin-bottom:20px;
}

/* Inputs */

.form-control,
.form-select{
background:rgba(255,255,255,0.15);
border:none;
color:green;
border-radius:10px;
padding:10px;
}

.form-control::placeholder{
color:#ddd;
}

.form-label{
font-size:14px;
opacity:0.9;
}

/* Book Button */

.book-btn{
width:100%;
padding:14px;
font-size:18px;
border-radius:12px;
border:none;
background:linear-gradient(90deg,#00c6ff,#0072ff);
color:white;
font-weight:600;
transition:0.3s;
}

.book-btn:hover{
transform:scale(1.03);
box-shadow:0 5px 15px rgba(0,0,0,0.4);
}

</style>
</head>

<body>

<div class="booking-card">
<img src="<%= listing.image.url %>" class="listing-img" alt="listing_image">
<div class="title"><%= listing.title %></div>

<div class="location">📍 <%= listing.location %></div>

<div class="price">
₹ <%= listing.price %> / night
</div>

<form>

<div class="mb-3">
<label class="form-label">Check In</label>
<input type="date" class="form-control">
</div>

<div class="mb-3">
<label class="form-label">Check Out</label>
<input type="date" class="form-control">
</div>

<div class="mb-3">
<label class="form-label">Guests</label>
<select class="form-select">
<option>1 Guest</option>
<option>2 Guests</option>
<option>3 Guests</option>
<option>4 Guests</option>
</select>
</div>

<div class="mb-3">
<label class="form-label">Special Request</label>
<textarea class="form-control" rows="2" placeholder="Any special request..."></textarea>
</div>

</form>

<button onclick="payNow()" class="book-btn">
Book Now & Pay ₹<%= listing.price %>
</button>

</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>

async function payNow() {

const res = await fetch("/listings/<%= listing._id %>/create-order",{
method:"POST"
});

const order = await res.json();

var options = {

key:"<%= razorpayKey %>",
amount:order.amount,
currency:"INR",
order_id:order.id,

name:"Business Management & Travel Booking",
description:"Hotel Booking Payment",

handler:function(response){

window.location.href="/listings/<%= listing._id %>/confirm";

}

};

var rzp = new Razorpay(options);

rzp.open();

}

</script>

</body>
</html>
